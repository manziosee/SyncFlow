# ──────────────────────────────────────────────────────
# SyncFlow Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ──────────────────────────────────────────────────────

# URL of the Phoenix/Elixir API backend (no trailing slash)
# Development: http://localhost:4000
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# Phoenix WebSocket endpoint for real-time features
# Development: ws://localhost:4000/socket/websocket
# Production:  wss://api.yourdomain.com/socket/websocket
NEXT_PUBLIC_WS_URL=ws://localhost:4000/socket/websocket
