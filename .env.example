# Database
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost/syncflow_dev
EVENT_STORE_URL=postgresql://postgres:postgres@localhost/syncflow_events

# Phoenix
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
GUARDIAN_SECRET=generate_with_mix_guardian_secret
LIVE_VIEW_SALT=generate_with_mix_phx_gen_secret_32
PHX_HOST=localhost
PORT=4000

# Email (Mailgun for production)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Redis
REDIS_URL=redis://localhost:6379

# AI (OpenAI or Anthropic for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
S3_BUCKET=syncflow-uploads

# Pool sizes
POOL_SIZE=10
