# =============================================================================
# Database (Neon PostgreSQL — https://neon.tech free tier)
# Copy this file to .env and fill in real values — never commit .env
# =============================================================================
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&channel_binding=require
EVENT_STORE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&channel_binding=require
POOL_SIZE=10

# =============================================================================
# Phoenix Secrets
# Generate with:  openssl rand -base64 64   (SECRET_KEY_BASE)
#                 openssl rand -base64 48   (GUARDIAN_SECRET)
#                 openssl rand -base64 32   (LIVE_VIEW_SALT)
# =============================================================================
SECRET_KEY_BASE=
GUARDIAN_SECRET=
LIVE_VIEW_SALT=

# =============================================================================
# Phoenix / Web
# =============================================================================
PHX_HOST=localhost
PORT=4000

# =============================================================================
# Email (Mailgun)
# =============================================================================
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AI — OpenAI + Groq
# =============================================================================
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# File Storage — Appwrite  (replaces AWS S3)
# =============================================================================
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_API_KEY=
APPWRITE_PROJECT_ID=
APPWRITE_BUCKET_ID=syncflow-uploads
